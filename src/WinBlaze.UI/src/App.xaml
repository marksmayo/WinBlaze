<Application
    x:Class="WinBlaze.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WinBlazeAppBackgroundBrush" Color="#FFF5F5F5" />
        <SolidColorBrush x:Key="WinBlazeCardBackgroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="WinBlazeCardBorderBrush" Color="#FF708090" />
        <SolidColorBrush x:Key="WinBlazeTextPrimaryBrush" Color="#FF000000" />
        <SolidColorBrush x:Key="WinBlazeTextOnAccentBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="WinBlazeSubtleBackgroundBrush" Color="#FFF5F5F5" />
