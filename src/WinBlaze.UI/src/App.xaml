<Application
    x:Class="WinBlaze.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!-- Modern Dark Theme with Electric Blue and Carbon HSL Accents -->
        
        <!-- Primary Background Colors -->
        <SolidColorBrush x:Key="WinBlazeAppBackgroundBrush" Color="#FF131313" />
        <SolidColorBrush x:Key="WinBlazeCardBackgroundBrush" Color="#FF202020" />
        <SolidColorBrush x:Key="WinBlazeCardHoverBrush" Color="#FF252525" />
        <SolidColorBrush x:Key="WinBlazeCardBorderBrush" Color="#FF2A2A2A" />
        
        <!-- Text Colors -->
        <SolidColorBrush x:Key="WinBlazeTextPrimaryBrush" Color="#FFE5E2E1" />
        <SolidColorBrush x:Key="WinBlazeTextSecondaryBrush" Color="#FFC0C7D4" />
        <SolidColorBrush x:Key="WinBlazeTextTertiaryBrush" Color="#80C0C7D4" />
        <SolidColorBrush x:Key="WinBlazeTextOnAccentBrush" Color="#FFFFFFFF" />
        
        <!-- Accent Colors - Modern Gradient Feel -->
        <LinearGradientBrush x:Key="WinBlazeAccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF0078D4" Offset="0"/>
            <GradientStop Color="#FFA3C9FF" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="WinBlazeAccentBrush" Color="#FF0078D4" />
        <SolidColorBrush x:Key="WinBlazeAccentHoverBrush" Color="#FF1A8AE2" />
        <SolidColorBrush x:Key="WinBlazeAccentPressedBrush" Color="#FF0066B3" />
        
        <!-- Subtle Background Colors -->
        <SolidColorBrush x:Key="WinBlazeSubtleBackgroundBrush" Color="#FF181818" />
        <SolidColorBrush x:Key="WinBlazeSubtleBorderBrush" Color="#FF252525" />
        <SolidColorBrush x:Key="WinBlazeElevatedBackgroundBrush" Color="#FF2A2A2A" />
        
        <!-- Status Colors -->
        <SolidColorBrush x:Key="WinBlazeErrorBackgroundBrush" Color="#33FFB4AB" />
        <SolidColorBrush x:Key="WinBlazeErrorBorderBrush" Color="#FFFFB4AB" />
        <SolidColorBrush x:Key="WinBlazeSuccessBackgroundBrush" Color="#334BD9E5" />
        <SolidColorBrush x:Key="WinBlazeSuccessBorderBrush" Color="#FF4BD9E5" />
        <SolidColorBrush x:Key="WinBlazeWarningBackgroundBrush" Color="#33FFDAD6" />
        <SolidColorBrush x:Key="WinBlazeWarningBorderBrush" Color="#FFFFDAD6" />
        
        <!-- Interactive Elements -->
        <SolidColorBrush x:Key="WinBlazeChipBackgroundBrush" Color="#FF252525" />
        <SolidColorBrush x:Key="WinBlazeChipActiveBackgroundBrush" Color="#FF0078D4" />
        <SolidColorBrush x:Key="WinBlazeChipInactiveBackgroundBrush" Color="#FF252525" />
        <SolidColorBrush x:Key="WinBlazeChipActiveBorderBrush" Color="#FF0078D4" />
        <SolidColorBrush x:Key="WinBlazeChipHoverBrush" Color="#FF2C2C2C" />
        
        <!-- Progress Bar Colors -->
        <SolidColorBrush x:Key="WinBlazeProgressTrackBrush" Color="#FF252525" />
        <LinearGradientBrush x:Key="WinBlazeProgressFillBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF0078D4" Offset="0"/>
            <GradientStop Color="#FF4BD9E5" Offset="0.5"/>
            <GradientStop Color="#FFA3C9FF" Offset="1"/>
        </LinearGradientBrush>
        
        <!-- File Type Accent Colors - Modern Palette -->
        <SolidColorBrush x:Key="WinBlazeVolumeAccentBrush" Color="#FF0078D4" />
        <SolidColorBrush x:Key="WinBlazeFolderAccentBrush" Color="#FF4BD9E5" />
        <SolidColorBrush x:Key="WinBlazeFileAccentBrush" Color="#FFA3C9FF" />
        <SolidColorBrush x:Key="WinBlazeArchiveAccentBrush" Color="#FFFFB4AB" />
        <SolidColorBrush x:Key="WinBlazeMediaAccentBrush" Color="#FFD8BAFF" />
        <SolidColorBrush x:Key="WinBlazeDocumentAccentBrush" Color="#FFC0C7D4" />
        
        <!-- Glassmorphism Effects -->
        <AcrylicBrush x:Key="WinBlazeAcrylicBackgroundBrush" 
                      TintColor="#131313" 
                      TintOpacity="0.8" 
                      FallbackColor="#FF131313" />
        
        <!-- Corner Radius -->
        <CornerRadius x:Key="WinBlazeCornerRadius">8</CornerRadius>
        <CornerRadius x:Key="WinBlazeSmallCornerRadius">6</CornerRadius>
        <CornerRadius x:Key="WinBlazeLargeCornerRadius">12</CornerRadius>
        
        <!-- Typography -->
        <FontFamily x:Key="WinBlazeHeaderFont">Metropolis</FontFamily>
        <FontFamily x:Key="WinBlazeBodyFont">Metropolis</FontFamily>
        
        <!-- Animations -->
        <Duration x:Key="WinBlazeAnimationDuration">0:0:0.3</Duration>
        <Duration x:Key="WinBlazeFastAnimationDuration">0:0:0.15</Duration>
        
        <!-- Modern Button Style -->
        <Style x:Key="WinBlazeModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource WinBlazeAccentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource WinBlazeTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        
        <!-- Modern Card Style -->
        <Style x:Key="WinBlazeCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource WinBlazeCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WinBlazeCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
        
        <!-- Modern TextBox Style -->
        <Style x:Key="WinBlazeModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource WinBlazeSubtleBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource WinBlazeTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WinBlazeSubtleBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="PlaceholderForeground" Value="{StaticResource WinBlazeTextTertiaryBrush}"/>
        </Style>
    </Application.Resources>
</Application>