  <Target Name="PrepareXamlReferencePaths" BeforeTargets="MarkupCompilePass1;MarkupCompilePass2" DependsOnTargets="GetCppWinRTPlatformWinMDReferences;GetCppWinRTDirectWinMDReferences;CppWinRTGetResolvedWinMD">
    <ItemGroup>
      <ReferencePath Include="@(CppWinRTPlatformWinMDReferences)" />
      <ReferencePath Include="@(CppWinRTDirectWinMDReferences)" />
      <ReferencePath Include="@(CppWinRTStaticProjectWinMDReferences)" />
